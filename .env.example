# ============================================================
# FormoSA Ride 環島通 — 環境變數範本（v12.0 最終版）
# 複製為 .env.local 後填入實際值（.env.local 已在 .gitignore，絕不提交）
# ============================================================

# ── 地圖（MapLibre + MapTiler）── Phase 3 必需
# 申請：https://cloud.maptiler.com（免費方案 10萬 tiles/月）
NEXT_PUBLIC_MAP_PROVIDER_BASE_URL=https://api.maptiler.com
NEXT_PUBLIC_MAP_PROVIDER_KEY=

# ── 資料庫（Supabase）── Phase 2 必需
# 申請：https://supabase.com → New Project → Settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=          # 僅後端使用，絕不出現在前端

# ── 天氣（交通部中央氣象署）── Phase 7 必需
# 申請：https://opendata.cwa.gov.tw → 註冊會員 → 取得 API 授權碼
CWA_API_KEY=

# ── 日出日落（SunriseSunset.io）── 免 API Key，直接呼叫
# 端點：https://api.sunrisesunset.io/json

# ── OSM Overpass API ── 免 API Key
# 端點：https://overpass-api.de/api/interpreter
# ⚠️ 呼叫時必須帶自訂 User-Agent header，否則會被 406 拒絕（2026-07-09 實測）

# ── 付款（Lemon Squeezy，v12.0 兩階段部署）──
# 第一階段：PAYMENT_ENABLED=false，以下四個留空
# 第二階段：網站上線後至 lemonsqueezy.com 申請，填入後改 true
PAYMENT_ENABLED=false
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_STORE_ID=
LEMONSQUEEZY_PRODUCT_ID=
LEMONSQUEEZY_WEBHOOK_SECRET=

# ── Email（Resend.com，付款確認信）── Phase 16D/18B
# 申請：https://resend.com（免費方案每天 100 封）
RESEND_API_KEY=

# ── 後台管理員 session 簽章 ── 自訂強密碼（建議 openssl rand -hex 32）
ADMIN_JWT_SECRET=

# ── Vercel Cron 驗證 ── 自訂強密碼
CRON_SECRET=

# ── 錯誤監控（Sentry）── Phase 18A
# 申請：https://sentry.io（免費方案每月 5,000 事件）
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# ── 速率限制（Upstash Redis）── Phase 18A
# 申請：https://upstash.com（免費方案）
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── 部署 ──
NEXT_PUBLIC_SITE_URL=http://localhost:3000    # 上線後改為正式網域，如 https://formosaride.com
